{
  "name": "hotel-pms-backend",
  "version": "2.0.0",
  "description": "Hotel PMS REST API — v2 with RBAC, Housekeeping, Multi-tenancy",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "knex migrate:latest --knexfile src/knexfile.cjs",
    "migrate:rollback": "knex migrate:rollback --knexfile src/knexfile.cjs",
    "migrate:make": "knex migrate:make --knexfile src/knexfile.cjs",
    "seed": "knex seed:run --knexfile src/knexfile.cjs",
    "db:reset": "npm run migrate:rollback && npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}